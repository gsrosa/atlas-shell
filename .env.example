# Remote microfrontend entry points (override per environment)
NEXT_PUBLIC_REMOTE_AI_ASSISTANT_URL=http://localhost:3002/remoteEntry.js
NEXT_PUBLIC_REMOTE_USER_APP_URL=http://localhost:3003/remoteEntry.js
NEXT_PUBLIC_REMOTE_PAYMENT_APP_URL=http://localhost:3004/remoteEntry.js

# BFF base URL (tRPC at {NEXT_PUBLIC_API_URL}/trpc). Must match atlas-bff PORT.
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
