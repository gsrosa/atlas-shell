# Remote microfrontend entry points (override per environment)
VITE_REMOTE_SEARCH_APP_URL=http://localhost:3001/assets/remoteEntry.js
VITE_REMOTE_AI_ASSISTANT_URL=http://localhost:3002/assets/remoteEntry.js
VITE_REMOTE_USER_APP_URL=http://localhost:3003/assets/remoteEntry.js

# BFF base URL (tRPC at {VITE_API_URL}/trpc). Must match atlas-bff PORT; use CORS_ORIGINS on the BFF for this origin.
VITE_API_URL=http://127.0.0.1:4000
